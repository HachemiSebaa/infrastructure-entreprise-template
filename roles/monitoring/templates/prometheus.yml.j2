global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_scrape_interval }}

alerting:
  alertmanagers:
    - static_configs:
        - targets: ['localhost:{{ alertmanager_port }}']

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ['localhost:{{ prometheus_port }}']

  - job_name: node
    static_configs:
      - targets:
{% for host in groups['all'] %}
          - '{{ hostvars[host].ansible_host }}:{{ node_exporter_port }}'
{% endfor %}
